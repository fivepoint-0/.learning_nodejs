
<%- include('includes/head.ejs') %>
</head>
    
<%- include('includes/navigation.ejs') %>
    
    <main>
        <% if (prods.length > 0) { %>
            <div class="grid" style="padding-left: 5rem;">
                <% for (let product of prods) { %>
                <article class="card product-item">
                    <header class="card__header">
                        <h1 class="product__title"><%= product.title%></h1>
                    </header>
                    <div class="card__image"><img src="https://vignette.wikia.nocookie.net/2007scape/images/0/0d/Unholy_book_detail.png/revision/latest?cb=20180310092719" alt="Image not available." width="100px" height="100px" /></div>
                    <div class="card__content">
                        <h2 class="product__price">$19.99</h2>
                        <p class="product__description">A very interesting book to read when you're feeling Lorum Ipsum.</p>
                    </div>
                    <div class="card__actions"><button class="btn">Add to Cart</button></div>
                </article>
                <% } %>
            </div>
        <% } else { %>
            <h1 style="padding-left: 3rem;">No Products Found</h1>
        <% } %>
    </main>
<%- include('includes/end.ejs') %>
